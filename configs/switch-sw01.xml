<native xmlns="http://cisco.com/ns/yang/Cisco-IOS-XE-native">

  <hostname>LAB-RA07-A01-SW01</hostname>

  <interface>
    <GigabitEthernet>
      <name>1/0/1</name>
      <description>Laptop management port</description>
      <switchport>
        <mode>
          <access/>
        </mode>
        <access>
          <vlan>
            <vlan>10</vlan>
          </vlan>
        </access>
      </switchport>
    </GigabitEthernet>

    <GigabitEthernet>
      <name>1/0/2</name>
      <description>Router management link</description>
      <switchport>
        <mode>
          <access/>
        </mode>
        <access>
          <vlan>
            <vlan>10</vlan>
          </vlan>
        </access>
      </switchport>
    </GigabitEthernet>

    <Vlan>
      <name>10</name>
      <description>Management SVI</description>
      <ip>
        <address>
          <primary>
            <address>172.16.7.5</address>
            <mask>255.255.255.240</mask>
          </primary>
        </address>
      </ip>
    </Vlan>
  </interface>

  <ip>
    <default-gateway>172.16.7.2</default-gateway>
  </ip>

</native>

